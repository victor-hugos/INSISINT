# .env.local
# WARNING: This file contains placeholders. Do NOT commit real secret keys to a public repository. Replace placeholders with your real values and add .env.local to .gitignore if you keep secrets locally.

# Public runtime
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
ADMIN_EMAILS=you@domain.com,other@domain.com

# Optional: Instagram automation / webhook
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=YOUR_TOKEN
INSTAGRAM_ACCESS_TOKEN=YOUR_INSTAGRAM_TOKEN
DEMO_PROFILE_ID=YOUR_PROFILE_ID
